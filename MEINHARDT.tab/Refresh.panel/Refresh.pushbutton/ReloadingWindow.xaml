<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False"
        SizeToContent="WidthAndHeight" Topmost="True">
  <Border Background="#EEFFFFFF" CornerRadius="10" Padding="14">
    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
      <wfi:WindowsFormsHost x:Name="GifHost" Width="400" Height="200" />
      <TextBlock Text="Refreshing Meinhardt Tools..." FontWeight="Bold" FontSize="14" Margin="0,10,0,0" HorizontalAlignment="Center" Foreground="#004C97"/>
    </StackPanel>
  </Border>
</Window>
