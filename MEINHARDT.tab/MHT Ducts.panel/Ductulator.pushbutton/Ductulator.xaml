<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MHT Ductulator"
        Width="1260"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F3F4F6"
        Foreground="#1F2937">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" CornerRadius="10" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="MHT Ductulator" FontSize="19" FontWeight="Bold"/>

                <TextBlock Grid.Row="2" Text="Airflow (L/s)" Margin="0,4,0,4" FontWeight="SemiBold"/>
                <TextBox x:Name="InpAirflow" Grid.Row="3" Height="32" Padding="8,4" Text="240"/>

                <TextBlock Grid.Row="4" Text="Target Velocity (m/s)" Margin="0,8,0,4" FontWeight="SemiBold"/>
                <TextBox x:Name="InpVelocity" Grid.Row="5" Height="32" Padding="8,4" Text="4"/>

                <TextBlock Grid.Row="6" Text="Known Duct Width (mm)" Margin="0,8,0,4" FontWeight="SemiBold"/>
                <TextBox x:Name="InpWidth" Grid.Row="7" Height="32" Padding="8,4" Text="250"/>

                <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="0,10,0,8">
                    <Button Content="Calculate" Width="92" Height="30" Margin="0,0,8,0" Click="calculate_click"/>
                    <Button Content="Reset" Width="72" Height="30" Margin="0,0,8,0" Click="reset_click"/>
                    <Button Content="How To Use" Width="96" Height="30" Click="help_click"/>
                </StackPanel>

                <Border Grid.Row="9" Margin="0,4,0,6" CornerRadius="8" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Flowrate (m3/h)" FontWeight="SemiBold" Foreground="#374151"/>
                        <TextBlock x:Name="TxtFlowrate" Text="864" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="10" Margin="0,0,0,6" CornerRadius="8" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Round Equivalent Diameter (mm)" FontWeight="SemiBold" Foreground="#374151"/>
                        <TextBlock x:Name="TxtRoundDia" Text="276" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="11" Margin="0,0,0,4" CornerRadius="8" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Suggested Rect. Size (W x H mm)" FontWeight="SemiBold" Foreground="#374151"/>
                        <TextBlock x:Name="TxtRect" Text="250 x 250" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="13" Text="Tip: Use the tables as a fast check against your design intent." Foreground="#6B7280" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="260"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="10" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" Padding="12">
                <TextBlock x:Name="TxtHeader"
                           Text="Ductulator reference table view"
                           FontWeight="SemiBold"
                           FontSize="14"/>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="10" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Speed Through Round Duct" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid x:Name="RoundGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="{Binding BgColor}"/>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Diameter (mm)" Binding="{Binding Diameter}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                            <Setter Property="Foreground" Value="#1F2937"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Velocity (m/s)" Binding="{Binding Velocity}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="4,4"/>
                                            <Setter Property="Foreground" Value="#000000"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" CornerRadius="10" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Legend [m/s]" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid x:Name="LegendGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="{Binding BgColor}"/>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Range" Binding="{Binding Range}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#000000"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#111827"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="4" CornerRadius="10" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Speed Through Square Duct W x h" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <DataGrid x:Name="SquareGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="True"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="True"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              FrozenColumnCount="1"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
