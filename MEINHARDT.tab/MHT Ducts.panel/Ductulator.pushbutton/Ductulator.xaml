<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MHT Ductolator by GM"
        Width="1280"
        Height="840"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#EEF1F5"
        Foreground="#1A202C">

    <Window.Resources>
        <!-- Primary action button (Calculate) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1B3A6B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#254D8F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#122850"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button (Reset, Help) -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F4F8"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#90A4B7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input TextBox with focus ring -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1B3A6B"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared column header style for all DataGrids -->
        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Top header bar ── -->
        <Border Grid.Row="0" Background="#1B3A6B">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="MHT DUCTULATOR" FontSize="15" FontWeight="Bold"
                               Foreground="#FFFFFF" VerticalAlignment="Center"/>
                    <Border Width="1" Background="#3D5A8A" Margin="14,8"/>
                    <TextBlock Text="Duct Velocity Reference Tool" FontSize="12"
                               Foreground="#90B4D8" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="by GM · Meinhardt" FontSize="11"
                           Foreground="#5C7EA8" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Main body ── -->
        <Grid Grid.Row="1" Margin="14,12,14,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT PANEL ===== -->
            <Border Grid.Column="0" CornerRadius="10" Background="#FFFFFF"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Navy accent strip -->
                    <Border Grid.Column="0" Background="#1B3A6B" CornerRadius="10,0,0,10"/>
                    <!-- Content -->
                    <Grid Grid.Column="1" Margin="14,16,14,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- INPUTS label -->
                        <TextBlock Grid.Row="0" Text="INPUTS" FontSize="10" FontWeight="Bold"
                                   Foreground="#9AA5B4"/>

                        <!-- Airflow -->
                        <TextBlock Grid.Row="2" Text="Airflow (L/s)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#2D3748"/>
                        <TextBox x:Name="InpAirflow" Grid.Row="4" Style="{StaticResource InputBox}" Text="240"/>

                        <!-- Target Velocity -->
                        <TextBlock Grid.Row="6" Text="Target Velocity (m/s)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#2D3748"/>
                        <TextBox x:Name="InpVelocity" Grid.Row="8" Style="{StaticResource InputBox}" Text="4"/>

                        <!-- Known Duct Width -->
                        <TextBlock Grid.Row="10" Text="Known Duct Width (mm)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#2D3748"/>
                        <TextBox x:Name="InpWidth" Grid.Row="12" Style="{StaticResource InputBox}" Text="250"/>

                        <!-- Buttons -->
                        <Grid Grid.Row="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Calculate"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="calculate_click"/>
                            <Button Grid.Column="2" Content="Reset" Width="68"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="reset_click"/>
                            <Button Grid.Column="4" Content="?" Width="34"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="help_click"
                                    ToolTip="How to use this tool"/>
                        </Grid>

                        <!-- Divider -->
                        <Border Grid.Row="16" Height="1" Background="#E2E8F0"/>

                        <!-- RESULTS label -->
                        <TextBlock Grid.Row="18" Text="RESULTS" FontSize="10" FontWeight="Bold"
                                   Foreground="#9AA5B4"/>

                        <!-- Flowrate card — blue -->
                        <Border Grid.Row="20" CornerRadius="8" Background="#EBF4FF"
                                BorderBrush="#BEE3F8" BorderThickness="1" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="FLOWRATE" FontSize="10" FontWeight="Bold" Foreground="#2B6CB0"/>
                                    <TextBlock x:Name="TxtFlowrate" Text="864"
                                               FontSize="24" FontWeight="Bold" Foreground="#1A365D"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="m³/h" FontSize="12"
                                           Foreground="#4299E1" VerticalAlignment="Bottom" Margin="6,0,0,3"/>
                            </Grid>
                        </Border>

                        <!-- Round Diameter card — teal -->
                        <Border Grid.Row="22" CornerRadius="8" Background="#E6FFFA"
                                BorderBrush="#B2F5EA" BorderThickness="1" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="ROUND EQUIV. Ø" FontSize="10" FontWeight="Bold" Foreground="#276749"/>
                                    <TextBlock x:Name="TxtRoundDia" Text="276"
                                               FontSize="24" FontWeight="Bold" Foreground="#1C4532"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="mm" FontSize="12"
                                           Foreground="#38A169" VerticalAlignment="Bottom" Margin="6,0,0,3"/>
                            </Grid>
                        </Border>

                        <!-- Rect Size card — purple -->
                        <Border Grid.Row="24" CornerRadius="8" Background="#FAF5FF"
                                BorderBrush="#E9D8FD" BorderThickness="1" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="RECT. SIZE (W × H)" FontSize="10" FontWeight="Bold" Foreground="#553C9A"/>
                                    <TextBlock x:Name="TxtRect" Text="250 x 250"
                                               FontSize="22" FontWeight="Bold" Foreground="#322659"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="mm" FontSize="12"
                                           Foreground="#805AD5" VerticalAlignment="Bottom" Margin="6,0,0,3"/>
                            </Grid>
                        </Border>

                        <!-- Tip -->
                        <TextBlock Grid.Row="26"
                                   Text="Tip: Use the tables as a fast check against your design intent."
                                   Foreground="#9AA5B4" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===== RIGHT PANEL ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="260"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Active calculation header bar -->
                <Border Grid.Row="0" CornerRadius="10" Background="#FFFFFF"
                        BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,9">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="4" Background="#EBF4FF" Padding="7,3" Margin="0,0,10,0">
                            <TextBlock Text="ACTIVE CALC" FontSize="9" FontWeight="Bold" Foreground="#2B6CB0"/>
                        </Border>
                        <TextBlock x:Name="TxtHeader"
                                   Text="Ductulator reference table view"
                                   FontWeight="SemiBold" FontSize="13" Foreground="#2D3748"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Round duct + Legend row -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="215"/>
                    </Grid.ColumnDefinitions>

                    <!-- Round duct table -->
                    <Border Grid.Column="0" CornerRadius="10" Background="#FFFFFF"
                            BorderBrush="#E2E8F0" BorderThickness="1" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Row="0">
                                <Border CornerRadius="4" Background="#EBF4FF" Padding="7,3" Margin="0,0,8,0">
                                    <TextBlock Text="ROUND DUCT" FontSize="10" FontWeight="Bold" Foreground="#2B6CB0"/>
                                </Border>
                                <TextBlock Text="Velocity by diameter" FontSize="12"
                                           Foreground="#718096" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DataGrid x:Name="RoundGrid"
                                      Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#EDF2F7"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="{Binding BgColor}"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Diameter (mm)" Binding="{Binding Diameter}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="4,4"/>
                                                <Setter Property="Foreground" Value="#2D3748"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Velocity (m/s)" Binding="{Binding Velocity}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="15"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="4,4"/>
                                                <Setter Property="Foreground" Value="#1A202C"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Legend -->
                    <Border Grid.Column="2" CornerRadius="10" Background="#FFFFFF"
                            BorderBrush="#E2E8F0" BorderThickness="1" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Row="0">
                                <Border CornerRadius="4" Background="#FAF5FF" Padding="7,3" Margin="0,0,8,0">
                                    <TextBlock Text="LEGEND" FontSize="10" FontWeight="Bold" Foreground="#805AD5"/>
                                </Border>
                                <TextBlock Text="m/s bands" FontSize="12"
                                           Foreground="#718096" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DataGrid x:Name="LegendGrid"
                                      Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#EDF2F7"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="{Binding BgColor}"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Range" Binding="{Binding Range}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="4,4"/>
                                                <Setter Property="Foreground" Value="#1A202C"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="4,4"/>
                                                <Setter Property="Foreground" Value="#2D3748"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Rectangular duct table -->
                <Border Grid.Row="4" CornerRadius="10" Background="#FFFFFF"
                        BorderBrush="#E2E8F0" BorderThickness="1" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0">
                            <Border CornerRadius="4" Background="#FFF5F5" Padding="7,3" Margin="0,0,8,0">
                                <TextBlock Text="RECTANGULAR DUCT" FontSize="10" FontWeight="Bold" Foreground="#C53030"/>
                            </Border>
                            <TextBlock Text="Velocity (m/s) · Height rows × Width columns"
                                       FontSize="12" Foreground="#718096" VerticalAlignment="Center"/>
                        </StackPanel>
                        <DataGrid x:Name="SquareGrid"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="True"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  FrozenColumnCount="1"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#EDF2F7"
                                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
